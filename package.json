{
  "name": "xlayer-swap-router",
  "version": "1.0.1",
  "description": "Type what you want and it swaps on X Layer. Parses natural language (dozens of phrasings), quotes OKX OnchainOS and Uniswap in parallel, derives live prices from real quotes, picks slippage from volatility and pool depth, checks the wallet before execution. Uniswap side wired through Uniswap's official swap-integration AI skill.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swap": "dist/index.js",
    "xswap": "dist/index.js",
    "xlayer-swap": "dist/index.js",
    "xlayer-swap-router": "dist/index.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "node --require ts-node/register --test test/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ollie202/xlayer-swap-router.git"
  },
  "homepage": "https://github.com/Ollie202/xlayer-swap-router",
  "keywords": [
    "xlayer",
    "swap",
    "dex",
    "onchainos",
    "uniswap",
    "agent",
    "skill"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
